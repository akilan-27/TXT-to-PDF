{
  "name": "txt-to-pdf-pro",
  "version": "2.0.0",
  "description": "Professional TXT and Markdown to PDF converter with live preview. Fast, client-side, and free.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "dompurify": "^3.0.9",
    "highlight.js": "^11.9.0",
    "html2canvas": "^1.4.1",
    "jschardet": "^3.0.0",
    "jspdf": "^2.5.1",
    "katex": "^0.16.9",
    "marked": "^12.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "vite": "^5.4.0",
    "vitest": "^1.6.0",
    "jsdom": "^24.0.0"
  },
  "author": "Akilan R",
  "license": "MIT"
}
